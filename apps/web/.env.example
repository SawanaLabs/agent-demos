AI_GATEWAY_API_KEY=your_gateway_api_key
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v3/ai
AI_GATEWAY_CHAT_MODEL=openai/gpt-5-mini
DATABASE_URL=postgresql://user:password@localhost:5432/database
REDIS_URL=rediss://default:token@example.upstash.io:6379
CRON_SECRET=your_customer_memory_cleanup_secret
VERCEL_OIDC_TOKEN=your_vercel_oidc_token
# Optional OpenAI-compatible AI Gateway base URL for the OpenAI Agents SDK demo:
# OPENAI_AGENTS_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
# Optional explicit model override for the OpenAI Agents SDK demo:
# OPENAI_AGENTS_MODEL=openai/gpt-5-mini
# Optional reasoning override for the OpenAI Agents SDK demo:
# OPENAI_AGENTS_REASONING_EFFORT=medium
# Alternative local auth if OIDC is unavailable:
# VERCEL_TOKEN=your_vercel_access_token
# VERCEL_TEAM_ID=your_vercel_team_id
# VERCEL_PROJECT_ID=your_vercel_project_id
