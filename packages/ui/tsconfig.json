{
  "extends": "@workspace/typescript-config/react-library.json",
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@workspace/ui/*": ["./src/*"]
    },
    "strictNullChecks": true,
    "target": "ES2023"
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}
