{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "items": [
    {
      "name": "content-review",
      "type": "registry:block",
      "title": "Object Generation",
      "description": "A structured-output review workspace that streams a generated object directly inside the assistant message.",
      "dependencies": [
        "@ai-sdk/react",
        "@base-ui/react",
        "@phosphor-icons/react",
        "ai",
        "class-variance-authority",
        "lucide-react",
        "zod"
      ],
      "registryDependencies": [
        "utils",
        "badge",
        "button",
        "progress",
        "textarea",
        "https://elements.ai-sdk.dev/api/registry/attachments.json",
        "https://elements.ai-sdk.dev/api/registry/conversation.json",
        "https://elements.ai-sdk.dev/api/registry/message.json"
      ],
      "envVars": {
        "AI_GATEWAY_API_KEY": "",
        "AI_GATEWAY_BASE_URL": "https://ai-gateway.vercel.sh/v3/ai",
        "AI_GATEWAY_CHAT_MODEL": "openai/gpt-4.1-mini"
      },
      "files": [
        {
          "path": "app/demos/content-review/page.tsx",
          "type": "registry:page",
          "target": "app/demos/content-review/page.tsx"
        },
        {
          "path": "app/api/demos/content-review/route.ts",
          "type": "registry:page",
          "target": "app/api/demos/content-review/route.ts"
        },
        {
          "path": "app/api/demos/content-review/records/route.ts",
          "type": "registry:page",
          "target": "app/api/demos/content-review/records/route.ts"
        },
        {
          "path": "components/content-review/content-review-screen.tsx",
          "type": "registry:component",
          "target": "@components/content-review/content-review-screen.tsx"
        },
        {
          "path": "components/content-review/content-review-workspace.tsx",
          "type": "registry:component",
          "target": "@components/content-review/content-review-workspace.tsx"
        },
        {
          "path": "components/content-review/content-review-result-card.tsx",
          "type": "registry:component",
          "target": "@components/content-review/content-review-result-card.tsx"
        },
        {
          "path": "components/content-review/content-review-session.ts",
          "type": "registry:component",
          "target": "@components/content-review/content-review-session.ts"
        },
        {
          "path": "components/content-review/use-content-review-session.ts",
          "type": "registry:component",
          "target": "@components/content-review/use-content-review-session.ts"
        },
        {
          "path": "components/content-review/convert-files-to-review-attachments.ts",
          "type": "registry:component",
          "target": "@components/content-review/convert-files-to-review-attachments.ts"
        },
        {
          "path": "components/ai-elements/prompt-input.tsx",
          "type": "registry:component",
          "target": "@components/ai-elements/prompt-input.tsx"
        },
        {
          "path": "lib/content-review/env.ts",
          "type": "registry:lib",
          "target": "@lib/content-review/env.ts"
        },
        {
          "path": "lib/content-review/runtime.ts",
          "type": "registry:lib",
          "target": "@lib/content-review/runtime.ts"
        },
        {
          "path": "lib/content-review/recorded-review-run.ts",
          "type": "registry:lib",
          "target": "@lib/content-review/recorded-review-run.ts"
        },
        {
          "path": "lib/content-review/review-records.ts",
          "type": "registry:lib",
          "target": "@lib/content-review/review-records.ts"
        },
        {
          "path": "lib/content-review/record.ts",
          "type": "registry:lib",
          "target": "@lib/content-review/record.ts"
        },
        {
          "path": "lib/content-review/schema.ts",
          "type": "registry:lib",
          "target": "@lib/content-review/schema.ts"
        }
      ],
      "docs": "Install into a Next.js App Router project initialized with shadcn/ui. This item adds the object-generation demo page, streaming review routes, client workspace, and AI Gateway env vars required for structured output over text, image, and PDF inputs."
    }
  ]
}
